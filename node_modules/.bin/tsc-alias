else
  export NODE_PATH="/mnt/d/01_work/01 coding/CPE Lab/lec07/lec07/node_modules/.pnpm/tsc-alias@1.9.1/node_modules/tsc-alias/node_modules:/mnt/d/01_work/01 coding/CPE Lab/lec07/lec07/node_modules/.pnpm/tsc-alias@1.9.1/node_modules:/mnt/d/01_work/01 coding/CPE Lab/lec07/lec07/node_modules/.pnpm/node_modules:$NODE_PATH"
